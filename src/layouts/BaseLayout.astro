---
import Analytics from "@vercel/analytics/astro";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, structuredData } = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogType = Astro.url.pathname.startsWith("/guides/") ? "article" : "website";
const structuredDataList = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {structuredDataList.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <style is:global>
      :root {
        --border: #d8e2ef;
        --border-strong: #c3d2e3;
        --text: #0f172a;
        --muted: #5a6b81;
        --bg: #f3f6fb;
        --surface: rgba(255, 255, 255, 0.84);
        --surface-strong: #ffffff;
        --surface-tint: #eef4fb;
        --soft: #eef9f5;
        --brand: #0f766e;
        --brand-dark: #0b5b55;
        --accent: #b45309;
        --ok: #15803d;
        --shadow-sm: 0 10px 24px rgba(15, 23, 42, 0.06);
        --shadow: 0 22px 56px rgba(15, 23, 42, 0.10);
        --radius-sm: 12px;
        --radius: 18px;
        --radius-lg: 24px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.5;
        background-image:
          linear-gradient(to bottom, rgba(255, 255, 255, 0.75), rgba(243, 246, 251, 0.96)),
          linear-gradient(to right, rgba(15, 118, 110, 0.03), rgba(29, 78, 216, 0.02));
      }

      a {
        color: var(--brand);
        text-underline-offset: 0.18em;
        transition: color 120ms ease;
      }

      a:hover {
        color: var(--brand-dark);
      }

      h1,
      h2,
      h3,
      p {
        overflow-wrap: anywhere;
      }

      h1 {
        margin: 0 0 1rem;
        max-width: 11ch;
        font-size: clamp(2.8rem, 5vw, 5.1rem);
        line-height: 0.94;
        letter-spacing: 0;
      }

      h2 {
        margin-top: 0;
        font-size: clamp(1.55rem, 2vw, 1.9rem);
      }

      h3 {
        font-size: 1.05rem;
      }

      p {
        margin-top: 0;
      }

      .site-header {
        border-bottom: 1px solid rgba(216, 226, 239, 0.86);
        background: rgba(243, 246, 251, 0.78);
        backdrop-filter: blur(18px);
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .site-header-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.25rem;
      }

      .site-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        font-size: 1.02rem;
        font-weight: 800;
        color: var(--text);
        text-decoration: none;
      }

      .site-brand-mark {
        display: inline-grid;
        width: 2.25rem;
        height: 2.25rem;
        place-items: center;
        border-radius: 14px;
        background: linear-gradient(135deg, #0f766e, #1d4ed8);
        color: #fff;
        font-size: 0.76rem;
        font-weight: 800;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22);
      }

      .site-brand:hover {
        color: var(--brand);
      }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-size: 0.94rem;
      }

      .site-nav a {
        color: var(--muted);
        font-weight: 700;
        text-decoration: none;
        padding: 0.6rem 0.8rem;
        border-radius: 999px;
      }

      .site-nav a:hover {
        color: var(--text);
        background: rgba(255, 255, 255, 0.82);
      }

      .page-wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem 5rem;
      }

      .hero {
        padding: 1.25rem 0 3rem;
      }

      .hero-shell {
        display: block;
      }

      .hero-copy {
        border: 1px solid rgba(216, 226, 239, 0.92);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(238, 244, 251, 0.88));
        padding: 2rem 2rem 2.1rem;
      }

      .hero-copy p {
        max-width: 56ch;
        margin: 0;
        color: var(--muted);
        font-size: 1.12rem;
        line-height: 1.65;
      }

      .section-block {
        margin-top: 1.2rem;
        padding: 1.45rem;
        border: 1px solid rgba(216, 226, 239, 0.92);
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, 0.72);
        box-shadow: var(--shadow-sm);
        backdrop-filter: blur(12px);
      }

      .calc-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .primary-button,
      .secondary-button {
        display: inline-flex;
        min-height: 46px;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.8rem 1.05rem;
        border: 1px solid transparent;
        font: inherit;
        font-weight: 800;
        text-decoration: none;
        cursor: pointer;
        box-shadow: none;
      }

      .primary-button {
        background: var(--brand);
        color: #fff;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
      }

      .primary-button:hover {
        background: var(--brand-dark);
        color: #fff;
      }

      .secondary-button {
        background: rgba(255, 255, 255, 0.82);
        border-color: rgba(195, 210, 227, 0.98);
        color: var(--text);
      }

      .secondary-button:hover {
        border-color: var(--brand);
        color: var(--brand);
      }

      .section-heading {
        margin: 0 0 1rem;
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
      }

      .section-heading p {
        margin: 0;
        color: var(--muted);
      }

      .resource-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        padding: 0;
        margin: 0;
        list-style: none;
      }

      .resource-list li {
        border: 0;
        border-radius: var(--radius);
        padding: 0;
        background: transparent;
        box-shadow: none;
      }

      .resource-card-link {
        display: block;
        height: 100%;
        border: 1px solid rgba(216, 226, 239, 0.9);
        border-radius: var(--radius);
        padding: 1.1rem 1.15rem;
        background: rgba(255, 255, 255, 0.84);
        box-shadow: var(--shadow-sm);
        text-decoration: none;
        color: inherit;
        transition:
          transform 140ms ease,
          border-color 140ms ease,
          box-shadow 140ms ease,
          background-color 140ms ease,
          color 140ms ease;
      }

      .resource-card-link:hover {
        transform: translateY(-2px);
        border-color: rgba(15, 118, 110, 0.26);
        box-shadow: var(--shadow);
        background: rgba(255, 255, 255, 0.94);
        color: inherit;
      }

      .resource-card-link:active {
        transform: translateY(1px);
        border-color: rgba(15, 118, 110, 0.34);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
        background: rgba(247, 250, 253, 0.98);
      }

      .resource-card-link:focus-visible {
        outline: none;
        border-color: rgba(15, 118, 110, 0.62);
        box-shadow:
          0 0 0 4px rgba(15, 118, 110, 0.12),
          var(--shadow);
      }

      .resource-card-link strong {
        display: block;
        font-weight: 800;
        font-size: 1.03rem;
        color: var(--brand);
      }

      .resource-card-link span {
        display: block;
        margin-top: 0.55rem;
        color: var(--muted);
        line-height: 1.55;
      }

      .calculator-block {
        margin: 2rem 0 0;
      }

      .calc-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(280px, 0.86fr);
        gap: 1rem;
        align-items: start;
        margin-top: 1.35rem;
      }

      .calc-panel,
      .helper-panel,
      .related-panel {
        border: 1px solid rgba(216, 226, 239, 0.94);
        border-radius: var(--radius);
        background: rgba(255, 255, 255, 0.76);
        box-shadow: var(--shadow-sm);
        backdrop-filter: blur(12px);
        padding: 1.15rem;
      }

      .calc-panel h3,
      .helper-panel h3,
      .related-panel h2 {
        margin-top: 0;
      }

      .calc-field {
        display: grid;
        gap: 0.35rem;
        margin-bottom: 1rem;
        font-weight: 700;
      }

      .calc-field.has-error input {
        border-color: #dc2626;
        box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.12);
        background: rgba(254, 242, 242, 0.95);
      }

      .calc-field input {
        width: 100%;
        max-width: 280px;
        min-height: 42px;
        border: 1px solid rgba(195, 210, 227, 0.96);
        border-radius: var(--radius-sm);
        background: rgba(247, 250, 253, 0.92);
        padding: 0.5rem 0.7rem;
        font: inherit;
        color: var(--text);
        transition:
          border-color 120ms ease,
          box-shadow 120ms ease,
          background-color 120ms ease;
      }

      .calc-field input:hover {
        border-color: rgba(138, 160, 189, 0.95);
      }

      .calc-field input:focus-visible {
        outline: none;
        border-color: rgba(15, 118, 110, 0.68);
        box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
        background: rgba(255, 255, 255, 0.96);
      }

      .compact-field input {
        max-width: 190px;
      }

      .field-note {
        display: block;
        max-width: 360px;
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 400;
        line-height: 1.4;
      }

      .error-message {
        display: block;
        color: #b91c1c;
        font-size: 0.88rem;
        font-weight: 600;
        line-height: 1.4;
      }

      .validation-alert {
        margin-bottom: 1rem;
        padding: 0.85rem 0.95rem;
        border: 1px solid rgba(220, 38, 38, 0.22);
        border-radius: var(--radius-sm);
        background: rgba(254, 242, 242, 0.96);
        color: #991b1b;
        font-weight: 600;
        line-height: 1.45;
      }

      .muted {
        color: var(--muted);
      }

      .result-card {
        display: grid;
        gap: 0.35rem;
        border: 1px solid rgba(187, 230, 213, 0.98);
        border-radius: var(--radius);
        background: linear-gradient(180deg, rgba(241, 252, 248, 0.96), rgba(236, 249, 244, 0.88));
        padding: 1.1rem;
      }

      .result-card span {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 700;
      }

      .result-card strong {
        color: var(--ok);
        font-size: 1.8rem;
        line-height: 1.1;
      }

      .result-list {
        margin: 1rem 0 0;
      }

      .result-list div {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1rem;
        padding: 0.8rem 0;
        border-bottom: 1px solid rgba(228, 235, 244, 0.96);
      }

      .result-list dt {
        color: var(--muted);
      }

      .result-list dd {
        margin: 0;
        font-weight: 800;
      }

      .summary-panel {
        margin-top: 1rem;
        border: 1px solid rgba(228, 235, 244, 0.98);
        border-radius: var(--radius-sm);
        background: rgba(249, 251, 254, 0.92);
        padding: 0.95rem;
        line-height: 1.55;
      }

      .helper-panel {
        margin-top: 1rem;
      }

      .related-panel {
        margin-top: 1.25rem;
      }

      .related-panel ul {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        padding: 0;
        margin: 0;
        list-style: none;
      }

      .related-panel li {
        border: 0;
        border-radius: var(--radius-sm);
        background: transparent;
        padding: 0;
      }

      .related-card-link {
        display: block;
        height: 100%;
        border: 1px solid rgba(216, 226, 239, 0.92);
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.88);
        padding: 0.85rem 0.95rem;
        font-weight: 750;
        text-decoration: none;
        color: inherit;
        transition:
          transform 140ms ease,
          border-color 140ms ease,
          box-shadow 140ms ease,
          background-color 140ms ease,
          color 140ms ease;
      }

      .related-card-link:hover {
        transform: translateY(-2px);
        border-color: rgba(15, 118, 110, 0.26);
        box-shadow: var(--shadow-sm);
        background: rgba(255, 255, 255, 0.96);
        color: var(--brand);
      }

      .related-card-link:active {
        transform: translateY(1px);
        border-color: rgba(15, 118, 110, 0.34);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
      }

      .related-card-link:focus-visible {
        outline: none;
        border-color: rgba(15, 118, 110, 0.62);
        box-shadow:
          0 0 0 4px rgba(15, 118, 110, 0.12),
          var(--shadow-sm);
      }

      .guide-article {
        max-width: 860px;
      }

      .tool-page-intro,
      .guide-page-intro {
        margin-bottom: 1.6rem;
        padding: 1.35rem 1.45rem;
        border: 1px solid rgba(216, 226, 239, 0.94);
        border-radius: var(--radius-lg);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(238, 244, 251, 0.86));
        box-shadow: var(--shadow-sm);
      }

      .tool-page-kicker,
      .guide-page-kicker {
        margin-bottom: 0.65rem;
        color: var(--brand);
        font-size: 0.82rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .tool-page-intro h1,
      .guide-page-intro h1 {
        margin-bottom: 0.8rem;
        max-width: 14ch;
      }

      .tool-page-intro p:last-child,
      .guide-page-intro p:last-child {
        max-width: 58ch;
        margin-bottom: 0;
        color: var(--muted);
        font-size: 1.08rem;
        line-height: 1.65;
      }

      .guide-section {
        margin-bottom: 1.25rem;
        padding: 1.25rem 1.3rem;
        border: 1px solid rgba(216, 226, 239, 0.94);
        border-radius: var(--radius);
        background: rgba(255, 255, 255, 0.78);
        box-shadow: var(--shadow-sm);
      }

      .guide-section h2 {
        margin-bottom: 0.9rem;
      }

      .guide-section p {
        line-height: 1.7;
        color: var(--text);
      }

      .guide-section p:last-child {
        margin-bottom: 0;
      }

      .guide-section ul {
        margin: 0.85rem 0 0;
        padding-left: 1.15rem;
      }

      .guide-section li {
        margin-bottom: 0.4rem;
        color: var(--text);
      }

      .guide-example {
        border: 1px solid rgba(216, 226, 239, 0.96);
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.84);
        padding: 0.95rem;
        font-weight: 750;
        box-shadow: var(--shadow-sm);
      }

      .guide-tool-links {
        margin-top: 1rem;
        border-top: 1px solid rgba(216, 226, 239, 0.94);
        padding-top: 1rem;
      }

      .guide-tool-links strong {
        display: block;
        margin-bottom: 0.7rem;
      }

      .guide-tool-links ul {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        padding: 0;
        margin: 0;
        list-style: none;
      }

      .guide-tool-links li {
        margin: 0;
      }

      .guide-calculator-callout {
        margin: 0 0 2rem;
        border: 1px solid rgba(187, 230, 213, 0.98);
        border-radius: var(--radius);
        background: linear-gradient(180deg, rgba(241, 252, 248, 0.95), rgba(236, 249, 244, 0.88));
        padding: 1.1rem;
        box-shadow: var(--shadow-sm);
      }

      .guide-calculator-callout p {
        margin-top: 0;
      }

      .guide-calculator-callout a {
        display: inline-flex;
        min-height: 44px;
        align-items: center;
        justify-content: center;
        padding: 0.72rem 1rem;
        border-radius: 999px;
        background: var(--brand);
        color: #fff;
        font-weight: 800;
        text-decoration: none;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
      }

      .guide-calculator-callout a:hover {
        color: #fff;
        background: var(--brand-dark);
      }

      .guide-tool-card-link {
        display: block;
        height: 100%;
        border: 1px solid rgba(216, 226, 239, 0.92);
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.88);
        padding: 0.85rem 0.95rem;
        color: inherit;
        text-decoration: none;
        font-weight: 750;
        transition:
          transform 140ms ease,
          border-color 140ms ease,
          box-shadow 140ms ease,
          background-color 140ms ease,
          color 140ms ease;
      }

      .guide-tool-card-link:hover {
        transform: translateY(-2px);
        border-color: rgba(15, 118, 110, 0.26);
        box-shadow: var(--shadow-sm);
        background: rgba(255, 255, 255, 0.96);
        color: var(--brand);
      }

      .guide-tool-card-link:active {
        transform: translateY(1px);
        border-color: rgba(15, 118, 110, 0.34);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
      }

      .guide-tool-card-link:focus-visible {
        outline: none;
        border-color: rgba(15, 118, 110, 0.62);
        box-shadow:
          0 0 0 4px rgba(15, 118, 110, 0.12),
          var(--shadow-sm);
      }

      @media (max-width: 860px) {
        .calc-grid {
          grid-template-columns: 1fr;
        }

        .resource-list {
          grid-template-columns: 1fr;
        }

        .related-panel ul {
          grid-template-columns: 1fr;
        }

        .guide-tool-links ul {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 620px) {
        .site-header-inner {
          align-items: flex-start;
          flex-direction: column;
        }

        .page-wrap {
          padding-top: 2rem;
        }

        .hero-copy,
        .section-block {
          padding: 1.1rem;
        }

        .section-heading {
          align-items: flex-start;
          flex-direction: column;
        }

        .primary-button,
        .secondary-button {
          width: 100%;
        }

        .calc-field input {
          max-width: none;
        }
      }
    </style>
    <style is:global>
      .calculator-block {
        margin: 2rem 0 0;
      }

      .calc-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 2rem;
        align-items: start;
        margin-top: 1.5rem;
      }

      .calc-panel,
      .helper-panel {
        border: 1px solid rgba(216, 226, 239, 0.94);
        border-radius: var(--radius);
        background: rgba(255, 255, 255, 0.76);
        box-shadow: var(--shadow-sm);
        backdrop-filter: blur(12px);
        padding: 1.15rem;
      }

      .calc-panel h3,
      .helper-panel h3 {
        margin-top: 0;
      }

      .calc-field {
        display: grid;
        gap: 0.35rem;
        width: max-content;
        max-width: 100%;
        margin-bottom: 1rem;
        font-weight: 700;
      }

      .calc-field input {
        width: 180px;
        max-width: 100%;
        min-height: 40px;
        border: 1px solid rgba(195, 210, 227, 0.96);
        border-radius: var(--radius-sm);
        background: rgba(247, 250, 253, 0.92);
        padding: 0.45rem 0.65rem;
        font: inherit;
        color: var(--text);
        transition:
          border-color 120ms ease,
          box-shadow 120ms ease,
          background-color 120ms ease;
      }

      .calc-field input:hover {
        border-color: rgba(138, 160, 189, 0.95);
      }

      .calc-field input:focus-visible {
        outline: none;
        border-color: rgba(15, 118, 110, 0.68);
        box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
        background: rgba(255, 255, 255, 0.96);
      }

      .compact-field input {
        width: 180px;
      }

      .calc-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1rem;
      }

      .primary-button,
      .secondary-button,
      .tc-primary-btn,
      .tc-secondary-btn,
      .tc-remove,
      .hw-primary-btn,
      .hw-secondary-btn,
      .ot-primary-btn,
      .ot-secondary-btn,
      .result-action-btn {
        transition:
          background-color 120ms ease,
          border-color 120ms ease,
          color 120ms ease,
          transform 80ms ease,
          box-shadow 120ms ease;
      }

      .primary-button:active,
      .tc-primary-btn:active,
      .hw-primary-btn:active,
      .ot-primary-btn:active,
      .result-action-print:active {
        background: var(--brand-dark);
        transform: translateY(1px);
      }

      .secondary-button:active,
      .tc-secondary-btn:active,
      .tc-remove:active,
      .hw-secondary-btn:active,
      .ot-secondary-btn:active {
        background: #e6edf3;
        border-color: var(--brand);
        transform: translateY(1px);
      }

      .muted {
        color: var(--muted);
      }

      .result-card {
        display: grid;
        gap: 0.35rem;
        border: 1px solid rgba(187, 230, 213, 0.98);
        border-radius: var(--radius);
        background: linear-gradient(180deg, rgba(241, 252, 248, 0.96), rgba(236, 249, 244, 0.88));
        padding: 1.1rem;
      }

      .result-card span {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 700;
      }

      .result-card strong {
        color: var(--ok);
        font-size: 1.8rem;
      }

      .result-list {
        margin: 1rem 0 0;
      }

      .result-list div {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1rem;
        padding: 0.8rem 0;
        border-bottom: 1px solid rgba(228, 235, 244, 0.96);
      }

      .result-list dt {
        color: var(--muted);
      }

      .result-list dd {
        margin: 0;
        font-weight: 800;
      }

      .summary-panel {
        margin-top: 1rem;
        border: 1px solid rgba(228, 235, 244, 0.98);
        border-radius: var(--radius-sm);
        background: rgba(249, 251, 254, 0.92);
        padding: 0.95rem;
        line-height: 1.55;
      }

      @media (max-width: 860px) {
        .calc-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 620px) {
        .primary-button,
        .secondary-button {
          width: auto;
        }

        .tool-page-intro,
        .guide-page-intro {
          padding: 1.05rem 1.1rem;
        }

        .calc-field,
        .calc-field input {
          width: 100%;
        }
      }
    </style>
  </head>
