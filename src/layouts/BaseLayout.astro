      <div class="site-header-inner">
        <a class="site-brand" href="/">
          <span class="site-brand-mark">WP</span>
          <span>{site.name}</span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/#tools">Tools</a>
          <a href="/#guides">Guides</a>
        </nav>
      </div>
    </header>

    <main class="page-wrap">
      <slot />
    </main>

    <Analytics />
  </body>
</html>
