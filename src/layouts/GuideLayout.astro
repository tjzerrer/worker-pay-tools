---
import BaseLayout from "./BaseLayout.astro";
import type { Guide } from "../data/guides";

interface Props {
  guide: Guide;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { guide, structuredData } = Astro.props;
---

<BaseLayout title={guide.title} description={guide.description} structuredData={structuredData}>
  <slot />
</BaseLayout>
