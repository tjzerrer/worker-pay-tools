---
let start = "";
let end = "";
let result = "";

function calculate() {
  if (!start || !end) return;

  const startTime = new Date(`1970-01-01T${start}:00`);
  const endTime = new Date(`1970-01-01T${end}:00`);

  let diff = (endTime.getTime() - startTime.getTime()) / (1000 * 60 * 60);

  if (diff < 0) diff += 24;

  result = diff.toFixed(2);
}
---

<div style="border:1px solid #ccc; padding:1rem; margin:2rem 0;">
  <h2>Hours Worked Calculator</h2>

  <div style="display:grid; gap:1rem; max-width:500px;">
    <div>
      <label for="start">Start Time</label><br />
      <input id="start" type="time" bind:value={start} />
    </div>

    <div>
      <label for="end">End Time</label><br />
      <input id="end" type="time" bind:value={end} />
    </div>

    <div>
      <button on:click={calculate}>Calculate</button>
    </div>
  </div>

  {result && (
    <div style="margin-top:2rem; padding:1rem; background:#f7f7f7; border:1px solid #ddd;">
      <p><strong>Total Hours:</strong> {result}</p>
    </div>
  )}
</div>