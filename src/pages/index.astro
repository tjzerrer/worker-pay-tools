---
import BaseLayout from "../layouts/BaseLayout.astro";
import { tools } from "../data/tools";
import { guides } from "../data/guides";
import { site } from "../data/site";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    description: site.description
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Worker Pay Tools",
    url: site.url,
    description:
      "Worker pay calculators and guides for time cards, overtime, salary conversions, and paycheck estimates."
  }
];
---

<BaseLayout
  title="Worker Pay Tools | Time Card, Overtime, Salary & Paycheck Calculators"
  description="Use fast worker pay calculators for time cards, overtime, paychecks, net pay, and salary conversions."
  structuredData={structuredData}
  socialImage="/social/home.png"
  socialImageAlt="Worker Pay Tools social preview card"
>
  <section class="hero">
    <div class="hero-shell">
      <div class="hero-copy">
        <h1>Worker Pay Tools</h1>
        <p>
          Fast calculators for time cards, overtime, paychecks, net pay, and
          salary conversions. Built for quick checks before payday.
        </p>
      </div>
    </div>
  </section>

  <section id="tools" class="section-block" aria-labelledby="tools-heading">
    <div class="section-heading">
      <div>
        <h2 id="tools-heading">Calculators</h2>
        <p>Pick the calculator that matches the pay question in front of you.</p>
      </div>
    </div>

    <ul class="resource-list">
      {tools.map((tool) => (
        <li>
          <a class="resource-card-link" href={`/tools/${tool.slug}/`}>
            <strong>{tool.title}</strong>
            <span>{tool.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section id="guides" class="section-block" aria-labelledby="guides-heading" style="margin-top: 1.25rem;">
    <div class="section-heading">
      <div>
        <h2 id="guides-heading">Guides</h2>
        <p>Short explainers for the math behind the tools.</p>
      </div>
    </div>

    <ul class="resource-list">
      {guides.map((guide) => (
        <li>
          <a class="resource-card-link" href={`/guides/${guide.slug}/`}>
            <strong>{guide.title}</strong>
            <span>{guide.description}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
