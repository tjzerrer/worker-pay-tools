---
import BaseLayout from "../layouts/BaseLayout.astro";
import { tools } from "../data/tools";
import { guides } from "../data/guides";
---

<BaseLayout
  title="Worker Pay Tools"
  description="Simple calculators for work hours, overtime, salary conversions, and paycheck estimates."
>
  <h1>Worker Pay Tools</h1>
  <p>Simple calculators and guides for time cards, overtime, salary conversions, and paycheck estimates.</p>

  <section>
    <h2>Tools</h2>
    <ul>
      {tools.map((tool) => (
        <li>
          <a href={`/tools/${tool.slug}/`}>{tool.title}</a> — {tool.description}
        </li>
      ))}
    </ul>
  </section>

  <section>
    <h2>Guides</h2>
    <ul>
      {guides.map((guide) => (
        <li>
          <a href={`/guides/${guide.slug}/`}>{guide.title}</a> — {guide.description}
        </li>
      ))}
    </ul>
    </section>
</BaseLayout>