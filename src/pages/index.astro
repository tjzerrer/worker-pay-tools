---
import BaseLayout from "../layouts/BaseLayout.astro";
import { tools } from "../data/tools";
import { guides } from "../data/guides";
---

<BaseLayout
  title="Worker Pay Tools"
  description="Simple calculators for work hours, overtime, salary conversions, and paycheck estimates."
>
  <section class="hero">
    <div class="hero-copy">
      <h1>Worker Pay Tools</h1>
      <p>
        Fast calculators for shifts, overtime, hourly wages, salary comparisons,
        and rough paycheck estimates. Built for quick checks before payday.
      </p>
    </div>
  </section>

  <section id="tools" aria-labelledby="tools-heading">
    <div class="section-heading">
      <div>
        <h2 id="tools-heading">Calculators</h2>
        <p>Pick the calculator that matches the pay question in front of you.</p>
      </div>
    </div>

    <ul class="resource-list">
      {tools.map((tool) => (
        <li>
          <a href={`/tools/${tool.slug}/`}>{tool.title}</a>
          <p>{tool.description}</p>
        </li>
      ))}
    </ul>
  </section>

  <section id="guides" aria-labelledby="guides-heading" style="margin-top: 3rem;">
    <div class="section-heading">
      <div>
        <h2 id="guides-heading">Guides</h2>
        <p>Short explainers for the math behind the tools.</p>
      </div>
    </div>

    <ul class="resource-list">
      {guides.map((guide) => (
        <li>
          <a href={`/guides/${guide.slug}/`}>{guide.title}</a>
          <p>{guide.description}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
