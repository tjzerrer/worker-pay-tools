---
import GuideLayout from "../../layouts/GuideLayout.astro";
import { guides } from "../../data/guides";
import { tools } from "../../data/tools";

export function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide }
  }));
}

const { guide } = Astro.props;

const relatedTools = guide.relatedToolSlugs
  ? tools.filter((tool) => guide.relatedToolSlugs?.includes(tool.slug))
  : [];
---

<GuideLayout guide={guide}>
  <article style="max-width: 850px;">
    <h1 style="font-size: 2.25rem; margin-bottom: 0.75rem;">{guide.title}</h1>
    <p style="font-size: 1.1rem; color: #555; margin-bottom: 2rem;">
      {guide.description}
    </p>

    {guide.sections?.map((section) => (
      <section style="margin-bottom: 2rem;">
        <h2 style="margin-bottom: 0.75rem;">{section.heading}</h2>
        {section.paragraphs.map((paragraph) => (
          <p style="margin-bottom: 1rem; line-height: 1.7;">{paragraph}</p>
        ))}
      </section>
    ))}

    {relatedTools.length > 0 && (
      <section
        style="
          margin-top: 2.5rem;
          border: 1px solid #ddd;
          padding: 1rem;
          background: #fafafa;
        "
      >
        <h2 style="margin-top: 0;">Related Tools</h2>
        <ul style="margin-bottom: 0;">
          {relatedTools.map((tool) => (
            <li>
              <a href={`/tools/${tool.slug}/`}>{tool.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</GuideLayout>