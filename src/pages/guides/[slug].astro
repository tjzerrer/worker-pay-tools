---
import GuideLayout from "../../layouts/GuideLayout.astro";
import { guides } from "../../data/guides";
import { tools } from "../../data/tools";
import { site } from "../../data/site";

export function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide }
  }));
}

const { guide } = Astro.props;
const guideUrl = `${site.url}/guides/${guide.slug}/`;

const relatedTools = guide.relatedToolSlugs
  ? guide.relatedToolSlugs
      .map((slug) => tools.find((tool) => tool.slug === slug))
      .filter((tool) => tool !== undefined)
  : [];

const primaryTool = relatedTools[0];

function findTools(slugs: string[] = []) {
  return slugs
    .map((slug) => tools.find((tool) => tool.slug === slug))
    .filter((tool) => tool !== undefined);
}

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: guide.title,
    description: guide.description,
    url: guideUrl,
    mainEntityOfPage: guideUrl,
    author: {
      "@type": "Organization",
      name: site.name
    },
    publisher: {
      "@type": "Organization",
      name: site.name,
      url: site.url
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: site.url
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Guides",
        item: `${site.url}/#guides`
      },
      {
        "@type": "ListItem",
        position: 3,
        name: guide.title,
        item: guideUrl
      }
    ]
  }
];
---

<GuideLayout guide={guide} structuredData={structuredData}>
  <article class="guide-article">
    <section class="guide-page-intro">
      <p class="guide-page-kicker">Guides</p>
      <h1>{guide.title}</h1>
      <p>{guide.description}</p>
    </section>

    {guide.sections?.map((section, index) => (
      <>
        <section class="guide-section">
          <h2>{section.heading}</h2>
          {section.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          {section.bullets && (
            <ul>
              {section.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          )}
          {section.example && <p class="guide-example">{section.example}</p>}
          {section.toolSlugs && (
            <div class="guide-tool-links">
              <strong>Helpful calculators:</strong>
              <ul>
                {findTools(section.toolSlugs).map((tool) => (
                  <li>
                    <a class="guide-tool-card-link" href={`/tools/${tool.slug}/`}>
                      {tool.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </section>

        {index === 0 && primaryTool && guide.calculatorPrompt && (
          <aside class="guide-calculator-callout">
            <p>{guide.calculatorPrompt}</p>
            <a href={`/tools/${primaryTool.slug}/`}>{primaryTool.title}</a>
          </aside>
        )}
      </>
    ))}

    {relatedTools.length > 0 && (
      <section class="related-panel">
        <h2>Related Tools</h2>
        <ul>
          {relatedTools.map((tool) => (
            <li>
              <a class="related-card-link" href={`/tools/${tool.slug}/`}>{tool.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</GuideLayout>
